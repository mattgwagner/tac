<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>OPORD 003 - Three Independent Raids</name>
  <description>AO HERRERA - 1st PLT, A CO, 4-211 INF. Three independent squad raids on small REAPER nodes. FOR TRAINING USE ONLY.</description>

  <Style id="style-enemy">
    <IconStyle>
      <color>ff0000ff</color>
      <scale>1.3</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/target.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ff0000ff</color><scale>1.0</scale></LabelStyle>
  </Style>
  <Style id="style-friendly">
    <IconStyle>
      <color>ffff6600</color>
      <scale>1.1</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/placemark_circle.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ffff6600</color><scale>0.9</scale></LabelStyle>
  </Style>

  <Folder>
    <name>Enemy Objectives</name>

    <Placemark>
      <name>OBJ COTTO (1st SQD)</name>
      <description>MP 0600 1538 - Small REAPER OP/cache at Bradenton Ave intersection. 2-4 PAX, small arms, hasty positions oriented S.</description>
      <styleUrl>#style-enemy</styleUrl>
      <Point><coordinates>-81.9742627,29.9656653,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>OBJ WHISKEY (2nd SQD)</name>
      <description>MP 0613 1532 - Small REAPER commo relay/cache in Conex City NE building. 2-4 PAX, small arms, operating from inside structure.</description>
      <styleUrl>#style-enemy</styleUrl>
      <Point><coordinates>-81.9729102,29.9651338,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>OBJ ZULU (3rd SQD)</name>
      <description>MP 0575 1524 - Small REAPER OP at Arcadia St / Clearwater Ave junction. 2-3 PAX, binoculars, notebook, radio. Oriented S and E.</description>
      <styleUrl>#style-enemy</styleUrl>
      <Point><coordinates>-81.9768412,29.9643828,0</coordinates></Point>
    </Placemark>
  </Folder>

  <Folder>
    <name>Squad Objectives</name>

    <Placemark>
      <name>1st SQD Raid (OBJ COTTO)</name>
      <description>Independent squad raid on small REAPER OP/cache at Bradenton Ave intersection.</description>
      <styleUrl>#style-friendly</styleUrl>
      <Point><coordinates>-81.9742627,29.9656653,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>2nd SQD Raid (OBJ WHISKEY)</name>
      <description>Independent squad raid on small REAPER commo relay in Conex City NE building.</description>
      <styleUrl>#style-friendly</styleUrl>
      <Point><coordinates>-81.9729102,29.9651338,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>3rd SQD Raid (OBJ ZULU)</name>
      <description>Independent squad raid on small REAPER OP at Arcadia/Clearwater junction.</description>
      <styleUrl>#style-friendly</styleUrl>
      <Point><coordinates>-81.9768412,29.9643828,0</coordinates></Point>
    </Placemark>
  </Folder>

</Document>
</kml>
