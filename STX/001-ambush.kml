<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>OPORD 001 - Three Independent Ambushes</name>
  <description>AO COTTO - 1st PLT, A CO, 4-211 INF. Three independent squad ambush sites. FOR TRAINING USE ONLY.</description>

  <Style id="style-enemy">
    <IconStyle>
      <color>ff0000ff</color>
      <scale>1.3</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/target.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ff0000ff</color><scale>1.0</scale></LabelStyle>
  </Style>
  <Style id="style-friendly">
    <IconStyle>
      <color>ffff6600</color>
      <scale>1.1</scale>
      <Icon><href>http://maps.google.com/mapfiles/kml/shapes/placemark_circle.png</href></Icon>
    </IconStyle>
    <LabelStyle><color>ffff6600</color><scale>0.9</scale></LabelStyle>
  </Style>

  <Folder>
    <name>Enemy Objectives</name>

    <Placemark>
      <name>OBJ FLUNKER (1st SQD)</name>
      <description>MP 0600 1530 - Linear ambush site along Bradenton Ave. Small REAPER patrol 3-4 PAX, moving S to N.</description>
      <styleUrl>#style-enemy</styleUrl>
      <Point><coordinates>-81.9742557,29.9649434,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>OBJ KLENDATHU (2nd SQD)</name>
      <description>MP 0585 1559 - Linear ambush site along unnamed N-S road, western LTA. Small REAPER patrol 3-4 PAX, moving N to S.</description>
      <styleUrl>#style-enemy</styleUrl>
      <Point><coordinates>-81.9757450,29.9675220,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>OBJ MALZ (3rd SQD)</name>
      <description>MP 0575 1538 - Linear ambush site at Clearwater Ave / unnamed road intersection, SW LTA. Small REAPER patrol 3-4 PAX, moving E to W.</description>
      <styleUrl>#style-enemy</styleUrl>
      <Point><coordinates>-81.9767750,29.9656230,0</coordinates></Point>
    </Placemark>
  </Folder>

  <Folder>
    <name>Squad Ambush Sites</name>

    <Placemark>
      <name>1st SQD Ambush (Western)</name>
      <description>Independent linear ambush at OBJ FLUNKER. Orient east onto Bradenton Ave. Break contact west to ORP.</description>
      <styleUrl>#style-friendly</styleUrl>
      <Point><coordinates>-81.9742557,29.9649434,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>2nd SQD Ambush (Northwestern)</name>
      <description>Independent linear ambush at OBJ KLENDATHU. Orient east onto unnamed N-S road. Break contact west to ORP.</description>
      <styleUrl>#style-friendly</styleUrl>
      <Point><coordinates>-81.9757450,29.9675220,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>3rd SQD Ambush (Southwestern)</name>
      <description>Independent linear ambush at OBJ MALZ. Orient north onto Clearwater Ave. Break contact south to ORP.</description>
      <styleUrl>#style-friendly</styleUrl>
      <Point><coordinates>-81.9767750,29.9656230,0</coordinates></Point>
    </Placemark>
  </Folder>

</Document>
</kml>
